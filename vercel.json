{
  "functions": {
    "src/app/api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "src/app/api/assistant/**/*.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "src/app/api/cron/**/*.js": {
      "memory": 512,
      "maxDuration": 300
    },
    "src/app/api/google/**/*.js": {
      "memory": 512,
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/aisensy/abandoned-cart-first-campaign",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/aisensy/abandoned-cart-second-campaign",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/aisensy/review-campaign",
      "schedule": "30 13 28 * *"
    },
    {
      "path": "/api/cron/meta/generate-catalogue",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/google/merchant/sync-products",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/meta/cleanup-old-catalogues",
      "schedule": "0 2 * * *"
    }
  ]
}
